configuration {
    show-icons: true;
    theme: "Adapta-Nokto";
    font: "CodeNewRoman Nerd Font 12";
    drun-display-format: "{icon} {name}";
    display-run: " ";
    display-drun: " ";
    display-window: " ";
    modi: "window,run,drun";
}

window {
    width: 50%;
    transparency: "real";
}

mainbox {
    children: [inputbar, listview];
}
