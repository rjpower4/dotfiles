# .bashrc

# Source global definitions
if [ -f /etc/bashrc ]; then
	. /etc/bashrc
fi

# User specific environment
if ! [[ "$PATH" =~ "$HOME/.local/bin:$HOME/bin:" ]]
then
    PATH="$HOME/.local/bin:$HOME/bin:$PATH"
fi
export PATH

# Uncomment the following line if you don't like systemctl's auto-paging feature:
# export SYSTEMD_PAGER=

# Path additions
export PATH="$HOME/.cargo/bin:$PATH"   # Rust
export PATH="$HOME/.emacs.d/bin:$PATH" # Doom Emacs

# RJ's aliases
alias vim="nvim"

if [ ! `command -v exa >/dev/null` ]; then
    alias ls="exa"
fi

if [ ! `command -v bat >/dev/null` ]; then
    alias cat="bat"
fi

if [ ! `command -v rg >/dev/null` ]; then
    alias grep="rg"
fi

# Install Aliases
if [ ! `command -v dnf >/dev/null` ]; then 
    alias dnfcu="dnf check-update"
    alias dnfu="sudo dnf upgrade"
    alias dnfs="dnf search"
    alias dnfi="sudo dnf install"
fi

# Directory Colors
eval $(dircolors $HOME/.config/dir_colors)

# PS1
export PS1="[\[\e[34m\]\u\[\e[m\]@\[\e[35m\]\h\[\e[m\] \[\e[33m\]\W\[\e[m\]]\\$ "

# So that gradle doesn't put all of it's shit in $HOME ... sigh
export GRADLE_USER_HOME="$HOME/.config/gradle"
