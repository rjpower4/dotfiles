# -*- mode: sh -*-

# Octave History
export OCTAVE_HISTFILE="$HOME/.cache/octave-history"

# Less history
export LESSHISTFILE="$HOME/.cache/less-history"
export LESSHISTSIZE=10000

# Wget
export WGETRC=$HOME/.config/wget/wgetrc

# Rust
export CARGO_HOME="$HOME/.local/opt/rust/cargo"
export RUSTUP_HOME="$HOME/.local/opt/rust/rustup"

# Julia
export JULIA_DEPOT_PATH="$HOME/.local/opt/julia/depot"

# Go
export GOPATH="$HOME/.local/opt/go"

# Clojure
export CLJ_CONFIG="$HOME/.config/clojure"
export LEIN_HOME="$HOME/.local/opt/lein"

# QT
export QT_QPA_PLATFORMTHEME="qt5ct"

# CCACHE
export CCACHE_CONFIGPATH="$HOME/.config/ccache/ccache.conf"

# Chicken
export CHICKEN_INCLUDE_PATH="$HOME/.cache/chicken/install/;$HOME/.cache/chicken/eggs/"
export CHICKEN_EGG_CACHE="$HOME/.cache/chicken/eggs"
export CHICKEN_INSTALL_REPOSITORY="$HOME/.cache/chicken/install"
export CHICKEN_REPOSITORY_PATH="/lib/chicken/11/:$HOME/.cache/chicken/install"
