" Vimrc file for Rolfe Power

set nocompatible

filetype plugin indent on

let mapleader=" "
set path+=**
set wildmenu
set incsearch
set hidden
set nobackup
set noswapfile
set t_Co=256
set number
set clipboard=unnamedplus
syntax enable
let g:rehash256 = 1

" Theme
set termguicolors

" Status Line
set laststatus=2
set noshowmode

" Tabbing
set expandtab
set smarttab
set shiftwidth=4
set tabstop=4
