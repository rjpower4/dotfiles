include-file = $HOME/.config/polybar/colors
include-file = $HOME/.config/polybar/modules/bspwm
include-file = $HOME/.config/polybar/modules/music
include-file = $HOME/.config/polybar/modules/date
include-file = $HOME/.config/polybar/modules/session
include-file = $HOME/.config/polybar/modules/memory
include-file = $HOME/.config/polybar/modules/pulseaudio
include-file = $HOME/.config/polybar/modules/cpu
include-file = $HOME/.config/polybar/modules/wlan

[bar/main]
width = 100%
height = 32
bottom = false
fixed-center = true

background = ${colors.black}
foreground = ${colors.fg}

modules-left = bspwm music
modules-right = memory cpu pulseaudio wlan date session

font-0 = "CodeNewRoman Nerd Font:style=Medium:size=12;3"
font-1 = "CodeNewRoman Nerd Font:style=Bold:size=12;3"
font-2 = "CodeNewRoman Nerd Font:size=16;4"
font-3 = "CodeNewRoman Nerd Font:size=16;4"

tray-background = ${colors.black}
tray-position = center
tray-max-size = 16

[settings]
screenchange-reload = true
